generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  items         SavedItem[]
  tags          Tag[]
  apiTokens     ApiToken[]
  folders       Folder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiToken {
  id         String   @id @default(cuid())
  userId     String
  name       String
  tokenHash  String   @unique
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Folder {
  id        String      @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     SavedItem[]

  @@index([userId])
}

model SavedItem {
  id           String      @id @default(cuid())
  userId       String
  folderId     String?
  sourceUrl    String
  title        String
  author       String?
  excerpt      String?
  siteName     String?
  contentHtml  String
  contentText  String?
  imageUrl     String?
  embedUrl     String?
  kind         String      @default("article")
  readAt       DateTime?
  archived     Boolean     @default(false)
  liked        Boolean     @default(false)
  likedAt      DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder       Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags         ItemTag[]
  highlights   Highlight[]

  @@index([userId])
  @@index([folderId])
}

model Tag {
  id     String    @id @default(cuid())
  userId String
  name   String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  ItemTag[]

  @@unique([userId, name])
}

model ItemTag {
  itemId String
  tagId  String
  item   SavedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model Highlight {
  id               String    @id @default(cuid())
  itemId           String
  paragraphId      Int
  startInParagraph Int
  endInParagraph   Int
  quotedText       String
  color            String    @default("amber")
  note             String?
  createdAt        DateTime  @default(now())
  item             SavedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}
