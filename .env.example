# Local dev (relative path; OneDrive workaround is handled in the app).
DATABASE_URL="file:./prisma/dev.db"

# Optional: wins over DATABASE_URL for SQLite. Use on hosts that inject a non-SQLite DATABASE_URL
# (e.g. Railway Postgres) while still running this SQLite image — usually unnecessary; the Docker
# entrypoint already forces file:/data/prod.db when DATABASE_URL is not file:*.
# SQLITE_DATABASE_URL="file:/data/prod.db"

# Required in production (e.g. openssl rand -base64 32).
AUTH_SECRET=""
# Public app URL (production: https://your-app.up.railway.app).
NEXTAUTH_URL="http://localhost:3000"

# Verify SQLite: with the app running, curl -s http://localhost:3000/api/health
# (expect {"ok":true,"database":"up"}). Railway uses the same path for deploy health checks.
